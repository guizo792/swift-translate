{
  "manifest_version": 3,
  "name": "Swift Translate",
  "version": "1.0",
  "description": "Instant translations, right where you read: Translates selected text via context menu and displays in a floating overlay.",
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "options_page": "options.html",
  "icons": {
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}